{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "clipboard-manager:allow-read-image",
    "core:window:allow-destroy",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://github.com/**" }
      ]
    }
  ]
}
